-- ================================================
-- PARSER
-- ================================================

local function ParseCommand(input)
    input = input:match("^%s*(.-)%s*$")
    if input:sub(1, #Settings.Prefix) ~= Settings.Prefix then return end
    input = input:sub(#Settings.Prefix + 1)
    local parts = {}
    for word in input:gmatch("%S+") do table.insert(parts, word) end
    if #parts == 0 then return end
    local cmd = table.remove(parts, 1):lower()
    if Commands[cmd] then
        local ok, err = pcall(Commands[cmd].func, parts)
        if not ok then
            Log("Error: " .. tostring(err), Color3.fromRGB(255, 80, 80))
        end
    else
        Log("Unknown: ;" .. cmd .. " | try ;help", Color3.fromRGB(255, 100, 80))
    end
end

local function SubmitInput()
    local text = InputBox.Text
    if text ~= "" then
        Log("> " .. text, Color3.fromRGB(140, 140, 200))
        ParseCommand(text)
        InputBox.Text = ""
    end
end

InputBox.FocusLost:Connect(function(enter)
    if enter then SubmitInput() end
end)
SendBtn.MouseButton1Click:Connect(SubmitInput)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.RightControl then
        TogglePanel()
    end
end)

